// apps/server/prisma/schema.prisma

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// 用户相关
// ============================================

model User {
  id           String   @id @default(uuid())
  openid       String?  @unique
  phone        String   @unique
  username     String?  @unique
  passwordHash String?  @map("password_hash")
  nickname     String
  avatar       String?
  userType     String   @default("pet_owner") @map("user_type") // pet_owner / provider
  status       String   @default("active") // active / inactive / banned
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  profile          UserProfile?
  provider         Provider?
  pets             Pet[]
  ordersAsOwner    Order[]        @relation("OrderOwner")
  ordersAsProvider Order[]        @relation("OrderProvider")
  orderIntents     OrderIntent[]
  posts            Post[]
  favorites        Favorite[]
  notifications    Notification[]
  reviews          Review[]
  comments         Comment[]
  follows          Follow[]       @relation("Follower")
  followings       Follow[]       @relation("Following")
  creditScore      CreditScore?
  creditRecords    CreditRecord[]
  roles            UserRole[]
  complaints       Complaint[]    @relation("Complainant")

  @@index([phone])
  @@index([userType])
  @@map("users")
}

model UserProfile {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  realName  String?  @map("real_name")
  gender    String? // male / female
  age       Int?
  address   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model Provider {
  id              String   @id @default(uuid())
  userId          String   @unique @map("user_id")
  idCardVerified  Boolean  @default(false) @map("id_card_verified")
  wechatScore     Int?     @map("wechat_score")
  trainingPassed  Boolean  @default(false) @map("training_passed")
  certifiedSitter Boolean  @default(false) @map("certified_sitter")
  rejectRate      Float    @default(0.0) @map("reject_rate") // 拒绝率
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([certifiedSitter])
  @@map("providers")
}

// ============================================
// 宠物相关
// ============================================

model Pet {
  id         String   @id @default(uuid())
  ownerId    String   @map("owner_id")
  name       String
  breed      String
  age        Float
  weight     Float?
  gender     String // male / female
  sterilized Boolean  @default(false)
  habits     String? // 特殊习性
  allergies  String? // 过敏史
  photos     String[]
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  owner  User    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  orders Order[]
  posts  Post[]

  @@index([ownerId])
  @@map("pets")
}

// ============================================
// 订单相关
// ============================================

model Order {
  id          String    @id @default(uuid())
  orderType   String    @map("order_type") // reward / platform
  serviceType String    @map("service_type") // feeding / walking / playing
  ownerId     String    @map("owner_id")
  providerId  String?   @map("provider_id")
  petId       String    @map("pet_id")
  serviceTime DateTime  @map("service_time")
  address     String
  amount      Float
  status      String    @default("pending_confirm") // pending_confirm / confirmed / in_progress / completed / cancelled
  remark      String?
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  owner     User           @relation("OrderOwner", fields: [ownerId], references: [id])
  provider  User?          @relation("OrderProvider", fields: [providerId], references: [id])
  pet       Pet            @relation(fields: [petId], references: [id])
  reward    OrderReward?
  platform  OrderPlatform?
  intents   OrderIntent[]
  sops      OrderSop[]
  review    Review?
  complaint Complaint?

  @@index([ownerId])
  @@index([providerId])
  @@index([status])
  @@index([orderType])
  @@map("orders")
}

model OrderReward {
  id            String   @id @default(uuid())
  orderId       String   @unique @map("order_id")
  rewardAmount  Float    @map("reward_amount")
  priceRangeMin Float    @map("price_range_min")
  priceRangeMax Float    @map("price_range_max")
  expireTime    DateTime @map("expire_time")
  createdAt     DateTime @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_rewards")
}

model OrderPlatform {
  id                 String   @id @default(uuid())
  orderId            String   @unique @map("order_id")
  platformPrice      Float    @map("platform_price")
  assignedProviderId String?  @map("assigned_provider_id")
  createdAt          DateTime @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_platforms")
}

model OrderIntent {
  id           String   @id @default(uuid())
  orderId      String   @map("order_id")
  providerId   String   @map("provider_id")
  intentStatus String   @default("pending") @map("intent_status") // pending / confirmed / rejected
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  order    Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  provider User  @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([orderId, providerId])
  @@index([orderId])
  @@index([providerId])
  @@map("order_intents")
}

model OrderSop {
  id          String    @id @default(uuid())
  orderId     String    @map("order_id")
  stepNumber  Int       @map("step_number") // 1-5
  stepName    String    @map("step_name") // 进门消毒 / 拍照打卡 / 执行服务 / 清理现场 / 离开拍照
  photos      String[]
  videos      String[]
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_sops")
}

// ============================================
// 评价与纠纷
// ============================================

model Review {
  id                 String   @id @default(uuid())
  orderId            String   @unique @map("order_id")
  reviewerId         String   @map("reviewer_id")
  attitudeRating     Int      @map("attitude_rating") // 1-5
  professionalRating Int      @map("professional_rating") // 1-5
  punctualityRating  Int      @map("punctuality_rating") // 1-5
  sopExecutionRating Int      @map("sop_execution_rating") // 1-5
  overallRating      Int      @map("overall_rating") // 1-5
  content            String?
  photos             String[]
  createdAt          DateTime @default(now()) @map("created_at")

  order    Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  reviewer User  @relation(fields: [reviewerId], references: [id], onDelete: Cascade)

  @@index([reviewerId])
  @@map("reviews")
}

model Complaint {
  id               String   @id @default(uuid())
  orderId          String   @unique @map("order_id")
  complainantId    String   @map("complainant_id")
  complaintType    String   @map("complaint_type") // service_quality / safety / payment / other
  evidence         String[] // 证据URL
  expectedSolution String?  @map("expected_solution")
  status           String   @default("pending") // pending / processing / resolved / closed
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  order       Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  complainant User               @relation("Complainant", fields: [complainantId], references: [id], onDelete: Cascade)
  resolution  DisputeResolution?

  @@index([complainantId])
  @@index([status])
  @@map("complaints")
}

model DisputeResolution {
  id               String   @id @default(uuid())
  complaintId      String   @unique @map("complaint_id")
  resolverId       String?  @map("resolver_id") // 客服ID
  resolutionType   String   @map("resolution_type") // support_complainant / support_provider / shared_responsibility / insufficient_evidence
  refundAmount     Float?   @map("refund_amount")
  scoreAdjustment  Float?   @map("score_adjustment") // 评分调整
  creditAdjustment Int?     @map("credit_adjustment") // 信用分调整
  reason           String?
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  complaint Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)

  @@index([resolverId])
  @@map("dispute_resolutions")
}

// ============================================
// 社区相关
// ============================================

model Post {
  id            String   @id @default(uuid())
  authorId      String   @map("author_id")
  content       String
  mediaUrls     String[] @map("media_urls")
  tags          String[]
  petId         String?  @map("pet_id")
  likesCount    Int      @default(0) @map("likes_count")
  commentsCount Int      @default(0) @map("comments_count")
  sharesCount   Int      @default(0) @map("shares_count")
  status        String   @default("published") // published / draft / deleted
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  author    User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  pet       Pet?       @relation(fields: [petId], references: [id])
  favorites Favorite[]
  comments  Comment[]

  @@index([authorId])
  @@index([createdAt])
  @@map("posts")
}

model Comment {
  id              String   @id @default(uuid())
  postId          String   @map("post_id")
  commenterId     String   @map("commenter_id")
  content         String
  parentCommentId String?  @map("parent_comment_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  commenter User      @relation(fields: [commenterId], references: [id], onDelete: Cascade)
  parent    Comment?  @relation("ParentComment", fields: [parentCommentId], references: [id])
  replies   Comment[] @relation("ParentComment")

  @@index([postId])
  @@index([commenterId])
  @@map("comments")
}

model Follow {
  id          String   @id @default(uuid())
  followerId  String   @map("follower_id")
  followingId String   @map("following_id")
  createdAt   DateTime @default(now()) @map("created_at")

  follower  User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@map("follows")
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  postId    String   @map("post_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([userId])
  @@index([postId])
  @@map("favorites")
}

// ============================================
// 消息通知
// ============================================

model Notification {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  type        String // message / order / system
  title       String
  content     String
  referenceId String?  @map("reference_id") // 关联的业务ID（订单ID、帖子ID等）
  isRead      Boolean  @default(false) @map("is_read")
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

// ============================================
// RBAC权限管理
// ============================================

model Role {
  id          String   @id @default(uuid())
  roleName    String   @unique @map("role_name")
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  permissions RolePermission[]
  users       UserRole[]

  @@index([isActive])
  @@map("roles")
}

model Permission {
  id             String   @id @default(uuid())
  permissionCode String   @unique @map("permission_code")
  permissionName String   @map("permission_name")
  module         String // user / order / content / finance / merchant / system
  type           String // menu / button / api
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  roles RolePermission[]

  @@index([module])
  @@index([type])
  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(uuid())
  roleId       String   @map("role_id")
  permissionId String   @map("permission_id")
  createdAt    DateTime @default(now()) @map("created_at")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  roleId    String   @map("role_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

model PermissionAuditLog {
  id            String   @id @default(uuid())
  operatorId    String   @map("operator_id")
  operationType String   @map("operation_type") // create_role / update_role / delete_role / assign_permission / remove_permission / assign_user_role / remove_user_role
  targetType    String   @map("target_type") // role / permission / user
  targetId      String   @map("target_id")
  changes       String? // JSON格式记录变更
  ip            String?
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([operatorId])
  @@index([createdAt])
  @@map("permission_audit_logs")
}

// ============================================
// 信用管理
// ============================================

model CreditScore {
  id          String   @id @default(uuid())
  userId      String   @unique @map("user_id")
  creditScore Int      @default(100) @map("credit_score")
  lastUpdated DateTime @default(now()) @map("last_updated")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([creditScore])
  @@map("credit_scores")
}

model CreditRecord {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  changeAmount   Int      @map("change_amount") // 正数增加，负数减少
  reason         String
  relatedOrderId String?  @map("related_order_id")
  createdAt      DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("credit_records")
}
