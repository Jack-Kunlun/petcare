# EditorConfig is awesome: https://EditorConfig.org

# 顶级配置文件
root = true

# 所有文件默认设置
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Markdown文件
[*.md]
trim_trailing_whitespace = false

# YAML文件
[*.{yml,yaml}]
indent_size = 2

# JSON文件
[*.json]
indent_size = 2

# Shell脚本
[*.{sh,bash,zsh}]
indent_style = space
indent_size = 2

# Makefile
[Makefile]
indent_style = tab

# Windows批处理文件
[*.{bat,cmd}]
end_of_line = crlf
