# PetCare 环境变量配置示例
# ⚠️ 警告：以下均为示例值，生产环境必须修改为强密码/密钥！
# 复制此文件为 .env.local 并填写实际值

# ===== 服务器配置 =====
PORT=3000
NODE_ENV=development

# ===== 数据库配置（独立配置项）=====
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=user
# ⚠️ 生产环境必须使用强密码！建议: openssl rand -base64 32
DB_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD
DB_NAME=petcare
DB_SCHEMA=public

# ===== Redis配置（独立配置项）=====
REDIS_HOST=localhost
REDIS_PORT=6379
# ⚠️ 生产环境必须设置强密码！建议: openssl rand -base64 24
REDIS_PASSWORD=CHANGE_ME_TO_STRONG_REDIS_PASSWORD

# ===== 异步任务 / Worker 配置 =====
# 生产者和独立 Worker 必须使用相同的前缀；不同环境应使用不同前缀。
QUEUE_PREFIX=petcare
# 单个 Worker 的并发任务数
WORKER_CONCURRENCY=5
# Transactional Outbox 的轮询间隔（毫秒）
OUTBOX_POLL_INTERVAL_MS=1000
# 悬赏订单超时关闭延迟（48 小时，单位：毫秒）
ORDER_TIMEOUT_DELAY_MS=172800000

# ===== JWT配置 =====
# ⚠️ 生产环境必须使用至少32字符的强随机密钥！
# 生成方法: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_48
JWT_EXPIRES_IN=7d
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
REFRESH_TOKEN_TTL_SECONDS=604800

# ===== 管理员认证初始化 =====
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PHONE=17679141878
DEFAULT_ADMIN_PASSWORD=CHANGE_ME_TO_A_STRONG_RANDOM_PASSWORD

# 仅限本地开发；生产环境必须留空并接入真实短信发送器
SMS_DEV_CODE=246810
SMS_CODE_TTL_SECONDS=300
SMS_SEND_COOLDOWN_SECONDS=60
SMS_HOURLY_LIMIT=5
SMS_MAX_ATTEMPTS=5
CAPTCHA_TTL_SECONDS=300
CAPTCHA_MAX_ATTEMPTS=5

# ===== API配置 =====
API_BASE_URL=http://localhost:8986/api

# ===== CORS配置 =====
# CORS允许的源（逗号分隔）
ALLOWED_ORIGINS=http://localhost:8986,http://127.0.0.1:8986

# ===== 第三方服务（可选）=====
# 微信AppID
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# 阿里云OSS（用于文件上传）
ALIYUN_OSS_ACCESS_KEY_ID=
ALIYUN_OSS_ACCESS_KEY_SECRET=
ALIYUN_OSS_BUCKET=
ALIYUN_OSS_REGION=


# ===== 端口暴露配置（开发/生产环境控制）=====
# 开发环境设置为对应端口号，生产环境留空以禁用外部访问
EXPOSE_DB_PORT=5432
EXPOSE_REDIS_PORT=6379
