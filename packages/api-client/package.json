{
  "name": "@petcare/api-client",
  "version": "1.0.0",
  "description": "PetCare API客户端封装",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "lint": "eslint .",
    "lint:staged": "eslint . --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:staged": "prettier --write \"src/**/*.ts\"",
    "test": "vitest run --passWithNoTests",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@petcare/shared-types": "workspace:*",
    "axios": "^1.18.1"
  },
  "devDependencies": {
    "@petcare/eslint-config-base": "workspace:*",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "9.39.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
